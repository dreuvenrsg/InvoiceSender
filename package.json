{
  "name": "InvoiceSender",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "repository": "https://github.com/dreuvenrsg/InvoiceSender.git",
  "author": "Doron Reuven <dreuven@rsgsecurity.com>",
  "license": "MIT",
  "scripts": {
    "test-local": "node index.js",
    "build": "sam build",
    "deploy-guided": "sam deploy --guided",
    "deploy": "sam build && sam deploy --no-confirm-changeset --stack-name rsg-invoice-processor --resolve-s3 --capabilities CAPABILITY_IAM",
    "remove": "aws cloudformation delete-stack --stack-name rsg-invoice-processor --region us-west-1",
    "info": "aws cloudformation describe-stacks --stack-name rsg-invoice-processor --region us-west-1",
    "invoke-local": "sam local invoke InvoiceProcessorFunction --event events/invoke.json",
    "logs": "aws logs tail /aws/lambda/RSGInvoiceProcessor --region us-west-1 --follow --since 1h"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.470.0",
    "@aws-sdk/client-ses": "^3.470.0",
    "@sparticuz/chromium": "^143.0.4",
    "puppeteer-core": "^24.38.0"
  },
  "devDependencies": {
    "puppeteer": "^24.38.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
